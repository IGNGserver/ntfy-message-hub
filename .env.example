NTFY_BASE_URL=https://example.com
NTFY_TOPICS=reports,messages
NTFY_TOKEN=replace-with-ntfy-token
RECORDER_USER=replace-with-recorder-user

MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_DATABASE=ntfy_message_store
